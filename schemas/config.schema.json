{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.disk-cleanup-skills/config.schema.json",
  "title": "disk-cleanup-skills config",
  "type": "object",
  "required": ["config_version", "tools", "scan", "storage", "cleanup", "logging"],
  "additionalProperties": false,
  "properties": {
    "config_version": { "type": "integer", "const": 1 },
    "tools": {
      "type": "object",
      "required": ["wiztree_executable"],
      "additionalProperties": false,
      "properties": {
        "wiztree_executable": { "type": "string", "minLength": 1 }
      }
    },
    "scan": {
      "type": "object",
      "required": ["targets", "request_admin", "include_files", "include_folders", "sort_by", "retain_scan_count"],
      "additionalProperties": false,
      "properties": {
        "targets": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1 },
        "request_admin": { "type": "boolean" },
        "include_files": { "type": "boolean" },
        "include_folders": { "type": "boolean" },
        "sort_by": { "type": "string" },
        "retain_scan_count": { "type": "integer", "minimum": 1 }
      }
    },
    "storage": {
      "type": "object",
      "required": ["workspace", "database_name"],
      "additionalProperties": false,
      "properties": {
        "workspace": { "type": "string", "minLength": 1 },
        "database_name": { "type": "string", "minLength": 1 }
      }
    },
    "cleanup": {
      "type": "object",
      "required": ["file_delete_mode", "require_preview", "verify_after_cleanup"],
      "additionalProperties": false,
      "properties": {
        "file_delete_mode": { "type": "string", "const": "recycle_bin" },
        "require_preview": { "type": "boolean", "const": true },
        "verify_after_cleanup": { "type": "boolean", "const": true }
      }
    },
    "logging": {
      "type": "object",
      "required": ["level", "retain_days"],
      "additionalProperties": false,
      "properties": {
        "level": { "type": "string" },
        "retain_days": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
